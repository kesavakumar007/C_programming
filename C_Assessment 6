#include <stdio.h>

int main() {
    int num, last, first, temp, digits = 0, place = 1, result;

    printf("Enter a number: ");
    scanf("%d", &num);

    temp = num;
    last = temp % 10;

    if(last % 2 == 0) {
        printf("Number = %d\n", num);
    }
    else {
        temp = num;

        while(temp != 0) {
            temp = temp / 10;
            digits++;
        }

        place = 1;
        for(int i = 1; i < digits; i++) {
            place = place * 10;
        }

        first = num / place;

        result = (first - 1) * place + (num % place);

        printf("Modified number = %d\n", result);
    }

    return 0;
}

