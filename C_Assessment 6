    int i, num, sum, digit;

    printf("Two-digit odd numbers whose sum of digits is 7:\n");

    for(i = 10; i < 100; i++) {
        if(i % 2 != 0) {   // check odd number
            num = i;
            sum = 0;

            while(num > 0) {
                digit = num % 10;
                sum += digit;
                num = num / 10;
