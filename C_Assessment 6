#include <stdio.h>

int main() {
    int num, first, last, temp, digits = 0, place = 1, middle, swapped;

    printf("Enter a number: ");
    scanf("%d", &num);

    temp = num;
    last = temp % 10;

    while(temp >= 10) {
        temp = temp / 10;
    }
    first = temp;

    temp = num;
    while(temp != 0) {
        temp = temp / 10;
        digits++;
    }

    place = 1;
    for(int i = 1; i < digits; i++) {
        place = place * 10;
    }

    middle = (num % place) / 10;

    swapped = last * place + middle * 10 + first;

    printf("After swapping first and last digit = %d\n", swapped);

    return 0;
}

