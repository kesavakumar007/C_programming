PROGRAM 14

#include <stdio.h>

int main() {
    int num, temp, first, last, digits, middle, result;

    printf("Enter a number: ");
    scanf("%d", &num);

    temp = num;
    last = num % 10;

    digits = 0;
    while(temp > 0) {
        digits++;
        temp = temp / 10;
    }

    temp = num;
    while(temp >= 10) {
        temp = temp / 10;
    }
    first = temp;

    int power = 1;
    for(int i = 1; i < digits; i++) {
        power *= 10;
    }

    middle = (num % power) / 10;

    result = last * power + middle * 10 + first;

    printf("Number after swapping = %d", result);

    return 0;
}

PROGRAM 15

#include <stdio.h>

int main() {
    int num, temp, lastDigit, digits = 0;
    long long result;

    printf("Enter a number: ");
    scanf("%d", &num);

    lastDigit = num % 10;

    if (lastDigit % 2 == 0) {
        temp = num;

        while (temp > 0) {
            digits++;
            temp /= 10;
        }

        long long power = 1;
        for (int i = 0; i < digits; i++) {
            power *= 10;
        }

        result = (long long)num * power + num;
        printf("Result = %lld", result);
    }
    else {
        temp = num;

        int power = 1;
        while (temp >= 10) {
            temp /= 10;
            power *= 10;
        }

        result = num - power;
        printf("Result = %lld", result);
    }

    return 0;
}

PROGRAM 16

#include <stdio.h>

int main() {
    int num, i, flag = 1;

    printf("Enter a number: ");
    scanf("%d", &num);

    if (num <= 1) {
        flag = 0;
    } else {
        for (i = 2; i < num; i++) {
            if (num % i == 0) {
                flag = 0;
                break;
            }
        }
    }

    if (flag == 1)
        printf("Prime Number");
    else
        printf("Not a Prime Number");

    return 0;
}


