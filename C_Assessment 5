PROGRAM 15

#include <stdio.h>

int main() {
    int num, temp, lastDigit, digits = 0;
    long long result;

    printf("Enter a number: ");
    scanf("%d", &num);

    lastDigit = num % 10;

    if (lastDigit % 2 == 0) {
        temp = num;

        while (temp > 0) {
            digits++;
            temp /= 10;
        }

        long long power = 1;
        for (int i = 0; i < digits; i++) {
            power *= 10;
        }

        result = (long long)num * power + num;
        printf("Result = %lld", result);
    }
    else {
        temp = num;

        int power = 1;
        while (temp >= 10) {
            temp /= 10;
            power *= 10;
        }

        result = num - power;
        printf("Result = %lld", result);
    }

    return 0;
}

