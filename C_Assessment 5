    int num, temp, digit, sum = 0, i, prime = 1;

    printf("Enter a number: ");
    scanf("%d", &num);

    /* Find sum of digits */
    temp = num;
    while(temp != 0) {
        digit = temp % 10;
        sum = sum + digit;
        temp = temp / 10;
    }

    /* Check prime */
    if(num <= 1) {
        prime = 0;
    } else {
        for(i = 2; i < num; i++) {
            if(num % i == 0) {
                prime = 0;
                break;
            }
        }
    }

    if(prime == 1 && sum == 14)
        printf("Prime and sum of digits is 14");
    else
        printf("Condition not satisfied");

    return 0;
}

